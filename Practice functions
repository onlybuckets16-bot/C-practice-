#include <stdio.h>
int add(int a, int b) 
{
    return a + b;
}
int square(int a) 
{
    return a*a;
}
int main() {
    char choice; 
    printf("enter your choice(a/s) \n");
    scanf("%c",&choice);
    
    if(choice == 'a') {
        printf("%d",add(7, 8));
    }
    else {
        printf("%d",square(4));
    }

    return 0;
}
